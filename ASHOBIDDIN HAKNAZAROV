<!DOCTYPE html>
<html lang="tg">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Doru TJ</title>

    <link rel="stylesheet" href="style.css">
</head>

<body>

<header>

<h1>💊 Doru TJ</h1>

<input
type="text"
id="search"
placeholder="Ҷустуҷӯи дору..."
>

</header>

<main id="drug-list">

</main>

<script src="script.js"></script>

</body>
</html>
body{
margin:0;
font-family:Arial;
background:#f5f5f5;
}

header{
background:#0aa84f;
padding:20px;
color:white;
text-align:center;
}

input{
width:90%;
padding:12px;
border:none;
border-radius:10px;
font-size:18px;
}

.card{

background:white;

margin:15px;

padding:15px;

border-radius:12px;

box-shadow:0 0 10px #ddd;

}
const drugs = [

{
name:"Парацетамол",
group:"Зидди таб",
use:"Барои паст кардани таб ва дард"
},

{
name:"Ибупрофен",
group:"NSAID",
use:"Барои дард ва илтиҳоб"
},

{
name:"Амоксициллин",
group:"Антибиотик",
use:"Барои сироятҳои бактериявӣ"
},

{
name:"Азитромицин",
group:"Антибиотик",
use:"Барои сироятҳои роҳҳои нафас"
},

{
name:"Цефтриаксон",
group:"Антибиотик",
use:"Барои сироятҳои вазнин"
}

];

const list=document.getElementById("drug-list");

function showDrugs(data){

list.innerHTML="";

data.forEach(drug=>{

list.innerHTML+=`

<div class="card">

<h2>${drug.name}</h2>

<p><b>Гурӯҳ:</b> ${drug.group}</p>

<p>${drug.use}</p>

</div>

`;

});

}

showDrugs(drugs);

document
.getElementById("search")
.addEventListener("input",function(){

const text=this.value.toLowerCase();

const result=drugs.filter(d=>

d.name.toLowerCase().includes(text)

);

showDrugs(result);

});
